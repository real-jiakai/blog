{{- $pctx := . -}}
{{- if .IsHome -}}{{ $pctx = .Site }}{{- end -}}
{{- $pages := slice -}}
{{- if or $.IsHome $.IsSection -}}
{{- $pages = $pctx.RegularPages -}}
{{- else -}}
{{- $pages = $pctx.Pages -}}
{{- end -}}
{{- $limit := .Site.Config.Services.RSS.Limit -}}
{{- if ge $limit 1 -}}
{{- $pages = $pages | first $limit -}}
{{- end -}}
{{- $channelTitle := .Site.Title -}}
{{- $channelDescription := i18n "rssFeedDescription" (dict "Site" .Site.Title) -}}
{{- if and .Title (ne .Title .Site.Title) -}}
  {{- $channelTitle = printf "%s%s%s" .Title (i18n "rssTitleSeparator") .Site.Title -}}
  {{- $channelDescription = i18n "rssFeedDescriptionSection" (dict "Section" .Title "Site" .Site.Title) -}}
{{- end -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
{{ printf "<?xml-stylesheet type=\"text/xsl\" href=\"/xslt/simple-rss.%s.xslt\" ?>" .Site.Language.Lang | safeHTML }}
<rss version="2.0"
     xmlns:atom="http://www.w3.org/2005/Atom"
     xmlns:blog="https://blog.gujiakai.top/ns/rss">
  <channel>
    <title>{{ $channelTitle | plainify | htmlUnescape | transform.XMLEscape | safeHTML }}</title>
    <link>{{ .Permalink | transform.XMLEscape | safeHTML }}</link>
    <description>{{ $channelDescription | plainify | htmlUnescape | transform.XMLEscape | safeHTML }}</description>
    <generator>Hugo -- gohugo.io</generator>{{ with .Site.LanguageCode }}
    <language>{{.}}</language>{{end}}{{ with .Site.Copyright }}
    <copyright>{{.}}</copyright>{{end}}{{ if not .Date.IsZero }}
    <lastBuildDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>{{ end }}
    {{- with .OutputFormats.Get "RSS" -}}
    {{ printf "<atom:link href=%q rel=\"self\" type=%q />" .Permalink .MediaType | safeHTML }}
    {{- end -}}
    {{ range $pages }}
    <item>
      <title>{{ .Title | plainify | htmlUnescape | transform.XMLEscape | safeHTML }}</title>
      <link>{{ .Permalink | transform.XMLEscape | safeHTML }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid>{{ .Permalink | transform.XMLEscape | safeHTML }}</guid>
      {{/* 浏览器 XSLT 只渲染纯文本摘要，避免折叠条目仍实例化全文中的数百张图片。 */}}
      <blog:summary>{{ .Summary | plainify | htmlUnescape | truncate 320 | transform.XMLEscape | safeHTML }}</blog:summary>
      {{/* RSS 阅读器仍可获得完整正文。 */}}
      <description>{{- .Content | html -}}</description>
    </item>
    {{ end }}
  </channel>
</rss>
